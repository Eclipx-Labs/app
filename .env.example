# WalletConnect Project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Alchemy RPC endpoints
VITE_ALCHEMY_SEPOLIA_URL=
VITE_ALCHEMY_MAINNET_URL=

# Deployed contract addresses (set after deployment)
VITE_SHIELD_FACTORY_SEPOLIA=
VITE_SHIELD_FACTORY_MAINNET=

# API base URL
VITE_API_URL=http://localhost:8080

# Set to false only when connecting to real contracts
VITE_DEV_MOCK=true
