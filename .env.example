# Qryptum dApp environment variables

# Sepolia testnet (address hardcoded in wagmi.ts - no need to set for Sepolia)
VITE_SHIELD_FACTORY_SEPOLIA=0x9a66500886344cbcce882137f263CB0c61aa99b1

# Ethereum Mainnet (set when mainnet deployment is live)
VITE_SHIELD_FACTORY_MAINNET=

# Local Hardhat node (default: first deployment address)
VITE_SHIELD_FACTORY_LOCAL=0x5FbDB2315678afecb367f032d93F642f64180aa3

# API base URL (leave empty to use BASE_URL prefix from Vite config)
VITE_API_URL=
